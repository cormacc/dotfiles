{
  "menus": {
    "pi": {
      "label": "pi agent",
      "key": ",",
      "items": {
        "m": { "label": "Switch model", "action": "passthrough:ctrl+l" },
        "t": { "label": "Cycle thinking", "action": "passthrough:shift+tab" },
        "o": { "label": "Toggle tool output", "action": "passthrough:ctrl+o" },
        "k": { "label": "Toggle thinking", "action": "passthrough:ctrl+t" },
        "e": { "label": "External editor", "action": "passthrough:ctrl+g" },
        "n": { "label": "New session", "action": "command:/new" },
        "r": { "label": "Resume session", "action": "command:/resume" },
        "b": { "label": "Session tree", "action": "command:/tree" },
        "c": { "label": "Compact", "action": "command:/compact" },
        "y": { "label": "Copy last response", "action": "command:/copy" },
        "s": { "label": "Settings", "action": "command:/settings" },
        "R": { "label": "Reload extensions", "action": "command:/reload" }
      }
    },
    "space": {
      "label": "Leader",
      "key": " ",
      "items": {
        "t": {
          "label": "+toggle",
          "items": {
            "E": {
              "label": "+editor",
              "items": {
                "e": { "label": "Emacs mode", "action": "keybindings:set-mode-emacs" },
                "v": { "label": "Vim mode", "action": "keybindings:set-mode-vim" }
              }
            }
          }
        }
      }
    }
  }
}
