# Strip volatile pi-coding-agent runtime fields (defaultProvider,
# defaultModel, lastChangelogVersion) from agents-config/pi/settings.json
# when staging. The filter must be registered per-clone via:
#     ./agents-config/install-git-filter.sh
# (the filter config lives in .git/config, which is not version-controlled).
agents-config/pi/settings.json filter=pi-settings
